@page
@model InventoryManagement.Web.Pages.Productos.IndexModel
@{
    ViewData["Title"] = "Productos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="display-6 mb-1 im-page-title">Productos</h1>
        <p class="text-muted mb-0">Maestro de productos.</p>
    </div>
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createProductModal">
        Nuevo producto
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        @Model.StatusMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-header bg-light d-flex justify-content-between align-items-center">
        <strong>Listado</strong>
        <span class="text-muted small" data-filter-count data-count-label="producto(s)">@Model.Products.Count producto(s)</span>
    </div>
    <div class="card-body">
        @if (Model.Products.Count == 0)
        {
            <p class="text-muted mb-0">No hay productos para mostrar.</p>
        }
        else
        {
            var categoryFilters = Model.Products
                .Select(product => product.Category)
                .Where(category => !string.IsNullOrWhiteSpace(category))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(category => category)
                .ToList();
            var statusFilters = Model.Products
                .Select(product => product.Status)
                .Where(status => !string.IsNullOrWhiteSpace(status))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(status => status)
                .ToList();
            var unitFilters = Model.Products
                .Select(product => product.UnitOfMeasureCode)
                .Where(unit => !string.IsNullOrWhiteSpace(unit))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(unit => unit)
                .ToList();
            <div data-filter-group>
                <div class="im-filter-panel mb-3">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label">Buscar</label>
                            <input type="text" class="form-control" placeholder="Nombre, código, unidad, moneda, descripción..." data-search-input />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Filtrar por categoría</label>
                            <div class="dropdown im-check-combo" data-filter-target="category" data-filter-placeholder="Todas las categorías" data-bs-auto-close="outside">
                                <button class="btn btn-outline-secondary dropdown-toggle w-100" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <span class="im-check-combo-label" data-filter-button-label>Todas las categorías</span>
                                </button>
                                <div class="dropdown-menu w-100 p-2 im-check-combo-menu">
                                    @foreach (var category in categoryFilters)
                                    {
                                        <label class="dropdown-item-text im-check-option">
                                            <input class="form-check-input" type="checkbox" value="@category" data-label="@category" />
                                            <span>@category</span>
                                        </label>
                                    }
                                </div>
                            </div>
                            <small class="im-filter-help">Puedes seleccionar varias categorías.</small>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Filtrar por unidad</label>
                            <div class="dropdown im-check-combo" data-filter-target="unit" data-filter-placeholder="Todas las unidades" data-bs-auto-close="outside">
                                <button class="btn btn-outline-secondary dropdown-toggle w-100" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <span class="im-check-combo-label" data-filter-button-label>Todas las unidades</span>
                                </button>
                                <div class="dropdown-menu w-100 p-2 im-check-combo-menu">
                                    @foreach (var unit in unitFilters)
                                    {
                                        <label class="dropdown-item-text im-check-option">
                                            <input class="form-check-input" type="checkbox" value="@unit" data-label="@unit" />
                                            <span>@unit</span>
                                        </label>
                                    }
                                </div>
                            </div>
                            <small class="im-filter-help">Puedes seleccionar varias unidades.</small>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Filtrar por estatus</label>
                            <div class="dropdown im-check-combo" data-filter-target="status" data-filter-placeholder="Todos los estatus" data-bs-auto-close="outside">
                                <button class="btn btn-outline-secondary dropdown-toggle w-100" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <span class="im-check-combo-label" data-filter-button-label>Todos los estatus</span>
                                </button>
                                <div class="dropdown-menu w-100 p-2 im-check-combo-menu">
                                    @foreach (var status in statusFilters)
                                    {
                                        <label class="dropdown-item-text im-check-option">
                                            <input class="form-check-input" type="checkbox" value="@status" data-label="@status" />
                                            <span>@status</span>
                                        </label>
                                    }
                                </div>
                            </div>
                            <small class="im-filter-help">Puedes seleccionar varios estatus.</small>
                        </div>
                    </div>
                </div>

                <div class="row row-cols-1 row-cols-md-2 row-cols-xl-4 g-3">
                    @foreach (var product in Model.Products)
                    {
                        var hasLowStock = product.Stock < product.MinimumStock;
                        var statusBadgeClass = string.Equals(product.Status, "Activo", StringComparison.OrdinalIgnoreCase)
                            ? "bg-success-subtle text-success border border-success-subtle"
                            : "bg-secondary-subtle text-secondary border border-secondary-subtle";
                        var stockBadgeClass = hasLowStock
                            ? "bg-danger-subtle text-danger border border-danger-subtle"
                            : "bg-success-subtle text-success border border-success-subtle";
                        var saleEquivalent = string.Equals(product.CurrencyCode, "USD", StringComparison.OrdinalIgnoreCase)
                            ? $"Eq. Bs. {product.SalePriceVes:N2}"
                            : $"Eq. USD {product.SalePriceUsd:N2}";
                        var purchaseEquivalent = string.Equals(product.CurrencyCode, "USD", StringComparison.OrdinalIgnoreCase)
                            ? $"Eq. Bs. {product.PurchasePriceVes:N2}"
                            : $"Eq. USD {product.PurchasePriceUsd:N2}";

                        <div class="col" data-filter-card data-category="@product.Category" data-unit="@product.UnitOfMeasureCode" data-status="@product.Status" data-search="@($"{product.Name} {product.Barcode} {product.Category} {product.UnitOfMeasureCode} {product.UnitOfMeasureName} {product.CurrencyCode} {product.Status} {product.Description}")">
                            <div class="card h-100 im-card im-card--tall">
                                <div class="card-body im-card-body">
                                    <div class="d-flex justify-content-between align-items-start gap-2 mb-2 im-card-header">
                                        <div>
                                            <h2 class="h5 mb-1 im-title">
                                                <span class="im-title-icon" aria-hidden="true">
                                                    <svg viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                                                        <path d="M2.5 3A1.5 1.5 0 0 1 4 1.5h8A1.5 1.5 0 0 1 13.5 3v10A1.5 1.5 0 0 1 12 14.5H4A1.5 1.5 0 0 1 2.5 13V3zM4 2.5a.5.5 0 0 0-.5.5v10a.5.5 0 0 0 .5.5h8a.5.5 0 0 0 .5-.5V3a.5.5 0 0 0-.5-.5H4z"/>
                                                        <path d="M5 5h6v1H5V5zm0 3h6v1H5V8zm0 3h4v1H5v-1z"/>
                                                    </svg>
                                                </span>
                                                <span>@product.Name</span>
                                            </h2>
                                            <div class="im-card-category-row">
                                                <span class="im-card-category-tag">@product.Category</span>
                                            </div>
                                        </div>
                                        <div class="d-flex flex-column align-items-end gap-2">
                                            <span class="badge rounded-pill @statusBadgeClass">@product.Status</span>
                                            <span class="badge rounded-pill @stockBadgeClass">@(hasLowStock ? "Stock bajo" : "Stock OK")</span>
                                        </div>
                                    </div>

                                    <div class="im-card-info-block">
                                        <div class="im-card-code-line">
                                            <span class="im-card-code-label">Código:</span>
                                            <span class="text-muted small im-card-code-value">@product.Barcode</span>
                                        </div>
                                    </div>
                                    <div class="im-barcode-wrap">
                                        <svg class="im-barcode" data-barcode="@product.Barcode" role="img" aria-label="Código de barra"></svg>
                                    </div>
                                    <div class="im-card-meta im-card-meta--details mt-1">
                                        <div class="text-muted small im-card-meta__item">Unidad: @product.UnitOfMeasureCode - @product.UnitOfMeasureName</div>
                                        <div class="text-muted small im-card-meta__item im-card-meta__item--end">Moneda base: @product.CurrencyCode</div>
                                    </div>
                                    <div>
                                        @if (!string.IsNullOrWhiteSpace(product.Description))
                                        {
                                            <div class="im-description-box mt-2">
                                                <div class="text-muted small fw-semibold mb-1">Descripcion</div>
                                                <div class="text-muted small mb-0">@product.Description</div>
                                            </div>
                                        }
                                    </div>

                                    <div class="row g-2 im-stats">
                                        <div class="col-12">
                                            <div class="im-stat im-stat--price rounded d-flex justify-content-between">
                                                <span class="text-muted">Venta</span>
                                                <span class="d-inline-flex align-items-baseline gap-3">
                                                    <strong>VES @product.SalePriceVes.ToString("N2")</strong>
                                                    <span class="text-muted small" data-bs-toggle="tooltip" data-bs-placement="top" title="Tasa: 1 USD = VES @product.UsdToVesRate.ToString("N2")">USD @product.SalePriceUsd.ToString("N2")</span>
                                                </span>
                                            </div>
                                        </div>
                                        <div class="col-12">
                                            <div class="im-stat rounded border d-flex justify-content-between">
                                                <span class="text-muted">Compra</span>
                                                <span class="d-inline-flex align-items-baseline gap-3">
                                                    <strong>VES @product.PurchasePriceVes.ToString("N2")</strong>
                                                    <span class="text-muted small" data-bs-toggle="tooltip" data-bs-placement="top" title="Tasa: 1 USD = VES @product.UsdToVesRate.ToString("N2")">USD @product.PurchasePriceUsd.ToString("N2")</span>
                                                </span>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="im-stat rounded border d-flex justify-content-between">
                                                <span class="text-muted">Stock</span>
                                                <strong>@product.Stock</strong>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="im-stat rounded border d-flex justify-content-between">
                                                <span class="text-muted">Mínimo</span>
                                                <strong>@product.MinimumStock</strong>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="im-card-actions">
                                        <form method="post" asp-page-handler="ToggleStatus" class="im-status-control">
                                            <input type="hidden" name="id" value="@product.Id" />
                                            <input type="hidden" name="currentStatus" value="@product.Status" />
                                            <button type="submit"
                                                    class="im-status-switch @(string.Equals(product.Status, "Activo", StringComparison.OrdinalIgnoreCase) ? "is-active" : "is-inactive")"
                                                    aria-label="Cambiar estado del producto"
                                                    aria-pressed="@(string.Equals(product.Status, "Activo", StringComparison.OrdinalIgnoreCase).ToString().ToLowerInvariant())">
                                                <span class="im-status-switch__thumb" aria-hidden="true"></span>
                                            </button>
                                        </form>
                                        <button type="button"
                                                class="im-icon-btn"
                                                data-bs-toggle="modal"
                                                data-bs-target="#editProductModal"
                                                data-product-id="@product.Id"
                                                data-product-name="@product.Name"
                                                data-product-barcode="@product.Barcode"
                                                data-product-description="@product.Description"
                                                data-product-currencycode="@product.CurrencyCode"
                                                data-product-purchaseprice="@product.PurchasePrice"
                                                data-product-saleprice="@product.SalePrice"
                                                data-product-stock="@product.Stock"
                                                data-product-minimumstock="@product.MinimumStock"
                                                data-product-category="@product.Category"
                                                data-product-unit="@product.UnitOfMeasureCode"
                                                aria-label="Editar producto">
                                            <svg viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg" width="16" height="16">
                                                <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l10-10zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207 11.207 2.5zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293l6.5-6.5zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325z"/>
                                            </svg>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="alert alert-light border mt-3 d-none" data-empty-message>
                    No hay productos con los filtros seleccionados.
                </div>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="createProductModal" tabindex="-1" aria-labelledby="createProductModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5" id="createProductModalLabel">Agregar producto</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <form method="post">
                <div class="modal-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Input.Name" class="form-label"></label>
                            <input asp-for="Input.Name" class="form-control" />
                            <span asp-validation-for="Input.Name" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Input.Barcode" class="form-label"></label>
                            <input asp-for="Input.Barcode" class="form-control" maxlength="20" inputmode="numeric" />
                            <span asp-validation-for="Input.Barcode" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Input.CategoryId" class="form-label"></label>
                            <select asp-for="Input.CategoryId" asp-items="Model.CategoryOptions" class="form-select">
                                <option value="">Seleccione una categoría</option>
                            </select>
                            <span asp-validation-for="Input.CategoryId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Input.UnitOfMeasureId" class="form-label"></label>
                            <select asp-for="Input.UnitOfMeasureId" asp-items="Model.UnitOfMeasureOptions" class="form-select">
                                <option value="">Seleccione una unidad</option>
                            </select>
                            <span asp-validation-for="Input.UnitOfMeasureId" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Input.CurrencyCode" class="form-label"></label>
                            <select asp-for="Input.CurrencyCode" asp-items="Model.CurrencyOptions" class="form-select">
                                <option value="">Seleccione una moneda</option>
                            </select>
                            <span asp-validation-for="Input.CurrencyCode" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Input.Description" class="form-label"></label>
                            <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Input.Description" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Input.PurchasePrice" class="form-label"></label>
                            <input asp-for="Input.PurchasePrice" class="form-control" />
                            <span asp-validation-for="Input.PurchasePrice" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Input.SalePrice" class="form-label"></label>
                            <input asp-for="Input.SalePrice" class="form-control" />
                            <span asp-validation-for="Input.SalePrice" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Input.Stock" class="form-label"></label>
                            <input asp-for="Input.Stock" class="form-control" />
                            <span asp-validation-for="Input.Stock" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Input.MinimumStock" class="form-label"></label>
                            <input asp-for="Input.MinimumStock" class="form-control" />
                            <span asp-validation-for="Input.MinimumStock" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editProductModal" tabindex="-1" aria-labelledby="editProductModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5" id="editProductModalLabel">Editar producto</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <form method="post" asp-page-handler="Update">
                <div class="modal-body">
                    <input type="hidden" asp-for="UpdateInput.Id" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="UpdateInput.Name" class="form-label"></label>
                            <input asp-for="UpdateInput.Name" class="form-control" id="edit-name" />
                            <span asp-validation-for="UpdateInput.Name" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="UpdateInput.Barcode" class="form-label"></label>
                            <input asp-for="UpdateInput.Barcode" class="form-control" id="edit-barcode" maxlength="20" inputmode="numeric" />
                            <span asp-validation-for="UpdateInput.Barcode" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="UpdateInput.CategoryId" class="form-label"></label>
                            <select asp-for="UpdateInput.CategoryId" asp-items="Model.CategoryOptions" class="form-select" id="edit-categoryId">
                                <option value="">Seleccione una categoria</option>
                            </select>
                            <span asp-validation-for="UpdateInput.CategoryId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="UpdateInput.UnitOfMeasureId" class="form-label"></label>
                            <select asp-for="UpdateInput.UnitOfMeasureId" asp-items="Model.UnitOfMeasureOptions" class="form-select" id="edit-unitOfMeasureId">
                                <option value="">Seleccione una unidad</option>
                            </select>
                            <span asp-validation-for="UpdateInput.UnitOfMeasureId" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="UpdateInput.CurrencyCode" class="form-label"></label>
                            <select asp-for="UpdateInput.CurrencyCode" asp-items="Model.CurrencyOptions" class="form-select" id="edit-currencyCode">
                                <option value="">Seleccione una moneda</option>
                            </select>
                            <span asp-validation-for="UpdateInput.CurrencyCode" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="UpdateInput.Description" class="form-label"></label>
                            <textarea asp-for="UpdateInput.Description" class="form-control" id="edit-description" rows="3"></textarea>
                            <span asp-validation-for="UpdateInput.Description" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="UpdateInput.PurchasePrice" class="form-label"></label>
                            <input asp-for="UpdateInput.PurchasePrice" class="form-control" id="edit-purchasePrice" />
                            <span asp-validation-for="UpdateInput.PurchasePrice" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="UpdateInput.SalePrice" class="form-label"></label>
                            <input asp-for="UpdateInput.SalePrice" class="form-control" id="edit-salePrice" />
                            <span asp-validation-for="UpdateInput.SalePrice" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="UpdateInput.Stock" class="form-label"></label>
                            <input asp-for="UpdateInput.Stock" class="form-control" id="edit-stock" />
                            <span asp-validation-for="UpdateInput.Stock" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="UpdateInput.MinimumStock" class="form-label"></label>
                            <input asp-for="UpdateInput.MinimumStock" class="form-control" id="edit-minimumStock" />
                            <span asp-validation-for="UpdateInput.MinimumStock" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Guardar cambios</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            var categoryMap = {};
            @foreach (var cat in Model.Categories)
            {
                <text>categoryMap["@cat.Name"] = @cat.Id;</text>
            }

            var unitMap = {};
            @foreach (var unit in Model.UnitsOfMeasure)
            {
                <text>unitMap["@unit.Code"] = @unit.Id;</text>
            }

            var editModal = document.getElementById("editProductModal");
            if (editModal) {
                editModal.addEventListener("show.bs.modal", function (event) {
                    var button = event.relatedTarget;
                    if (!button) return;

                    var id = button.getAttribute("data-product-id");
                    var name = button.getAttribute("data-product-name");
                    var barcode = button.getAttribute("data-product-barcode");
                    var description = button.getAttribute("data-product-description");
                    var currencyCode = button.getAttribute("data-product-currencycode");
                    var purchasePrice = button.getAttribute("data-product-purchaseprice");
                    var salePrice = button.getAttribute("data-product-saleprice");
                    var stock = button.getAttribute("data-product-stock");
                    var minimumStock = button.getAttribute("data-product-minimumstock");
                    var categoryName = button.getAttribute("data-product-category");
                    var unitCode = button.getAttribute("data-product-unit");

                    document.getElementById("edit-name").value = name || "";
                    document.getElementById("edit-barcode").value = barcode || "";
                    document.getElementById("edit-description").value = description || "";
                    document.getElementById("edit-purchasePrice").value = purchasePrice || "";
                    document.getElementById("edit-salePrice").value = salePrice || "";
                    document.getElementById("edit-stock").value = stock || "";
                    document.getElementById("edit-minimumStock").value = minimumStock || "";

                    var categoryId = categoryMap[categoryName] || "";
                    document.getElementById("edit-categoryId").value = categoryId;

                    var unitId = unitMap[unitCode] || "";
                    document.getElementById("edit-unitOfMeasureId").value = unitId;

                    var currencySelect = document.getElementById("edit-currencyCode");
                    if (currencySelect) {
                        currencySelect.value = currencyCode || "";
                    }
                });
            }
        })();
    </script>
}

