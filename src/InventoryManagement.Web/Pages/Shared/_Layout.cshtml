@using System.Net.Http.Headers
@using System.Net.Http.Json
@using InventoryManagement.Web.Models
@inject IHttpClientFactory HttpClientFactory
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - InventoryManagement</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/InventoryManagement.Web.styles.css" asp-append-version="true" />
</head>
<body>
    @{
        var isAuthenticated = !string.IsNullOrWhiteSpace(Context.Session.GetString(SessionKeys.AccessToken));
        var email = Context.Session.GetString(SessionKeys.Email);
        var username = Context.Session.GetString(SessionKeys.Username);
        var fullName = Context.Session.GetString(SessionKeys.FullName);
        var rolesCsv = Context.Session.GetString(SessionKeys.Roles);
        var roles = string.IsNullOrWhiteSpace(rolesCsv)
            ? Array.Empty<string>()
            : rolesCsv.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        var currentPage = ViewContext.ActionDescriptor.RouteValues["page"] ?? string.Empty;
        var lowStockNotifications = new List<ProductListItemViewModel>();

        if (isAuthenticated)
        {
            try
            {
                var accessToken = Context.Session.GetString(SessionKeys.AccessToken);
                if (!string.IsNullOrWhiteSpace(accessToken))
                {
                    var client = HttpClientFactory.CreateClient("InventoryApi");
                    client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", accessToken);
                    lowStockNotifications = await client.GetFromJsonAsync<List<ProductListItemViewModel>>("api/products/low-stock") ?? [];
                }
            }
            catch
            {
                lowStockNotifications = [];
            }
        }
    }
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid px-4">
                <a class="navbar-brand" asp-area="" asp-page="@(isAuthenticated ? "/Index" : "/Login")">Gestión de Inventario</a>
                <div class="im-navbar-quick-actions d-flex d-sm-none align-items-center gap-2 ms-auto">
                    @if (isAuthenticated)
                    {
                        <div class="dropdown">
                            <button type="button"
                                    class="btn p-0 border-0 bg-transparent im-circle-hover position-relative"
                                    data-bs-toggle="dropdown"
                                    data-bs-display="static"
                                    aria-expanded="false"
                                    aria-label="Ver notificaciones de stock bajo">
                                <span aria-hidden="true" class="im-icon-circle im-icon-circle-soft">
                                    <svg viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M8 1.5a3 3 0 0 0-3 3v1.087c0 .611-.134 1.214-.392 1.768L4 8.5v1h8v-1l-.608-1.145A4.207 4.207 0 0 1 11 5.587V4.5a3 3 0 0 0-3-3z"/>
                                        <path d="M14 10.5H2a.5.5 0 0 0-.5.5A1.5 1.5 0 0 0 3 12.5h10a1.5 1.5 0 0 0 1.5-1.5.5.5 0 0 0-.5-.5z"/>
                                        <path d="M6 13a2 2 0 1 0 4 0H6z"/>
                                    </svg>
                                </span>
                                @if (lowStockNotifications.Count > 0)
                                {
                                    <span class="im-notification-count">@lowStockNotifications.Count</span>
                                }
                            </button>
                            <div class="dropdown-menu dropdown-menu-end im-notification-menu p-0">
                                <div class="p-3">
                                    <div class="d-flex justify-content-between align-items-center gap-3">
                                        <div>
                                            <div class="im-user-menu-section-title mb-1">Notificaciones</div>
                                            <div class="text-muted small">Productos con stock bajo.</div>
                                        </div>
                                        <span class="badge rounded-pill text-bg-light im-role-badge">@lowStockNotifications.Count</span>
                                    </div>
                                    <div class="im-user-menu-section">
                                        @if (lowStockNotifications.Count == 0)
                                        {
                                            <div class="text-muted small">No hay alertas de stock bajo.</div>
                                        }
                                        else
                                        {
                                            @foreach (var product in lowStockNotifications.Take(6))
                                            {
                                                <div class="im-notification-item">
                                                    <div class="fw-semibold text-truncate">@product.Name</div>
                                                    <div class="text-muted small">Stock: @product.Stock | Minimo: @product.MinimumStock</div>
                                                </div>
                                            }
                                        }
                                    </div>
                                    <a class="btn btn-outline-primary w-100 rounded-pill fw-semibold mt-3" asp-page="/Inventario/Index">Ver productos con stock bajo</a>
                                </div>
                            </div>
                        </div>
                    }
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                </div>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between im-navbar-collapse">
                    <ul class="navbar-nav flex-grow-1">
                        @if (isAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark @(currentPage == "/Index" ? "im-nav-link-active" : string.Empty)" asp-area="" asp-page="/Index">Dashboard</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark @(currentPage == "/Productos/Index" ? "im-nav-link-active" : string.Empty)" asp-area="" asp-page="/Productos/Index">Productos</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark @(currentPage == "/Categorias/Index" ? "im-nav-link-active" : string.Empty)" asp-area="" asp-page="/Categorias/Index">Categorías</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark @(currentPage == "/Unidades/Index" ? "im-nav-link-active" : string.Empty)" asp-area="" asp-page="/Unidades/Index">Unidades</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark @(currentPage == "/Monedas/Index" ? "im-nav-link-active" : string.Empty)" asp-area="" asp-page="/Monedas/Index">Monedas</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark @(currentPage == "/Inventario/Index" ? "im-nav-link-active" : string.Empty)" asp-area="" asp-page="/Inventario/Index">Inventario</a>
                            </li>
                        }
                    </ul>
                    @if (isAuthenticated)
                    {
                        <div class="im-navbar-mobile-session d-sm-none">
                            @if (!string.IsNullOrWhiteSpace(email))
                            {
                                <div class="text-muted small mb-2">@email</div>
                            }
                            <form method="post" asp-page="/Logout" class="mb-0">
                                <button type="submit" class="btn btn-link p-0 text-decoration-none fw-semibold">Cerrar sesión</button>
                            </form>
                        </div>
                    }
                    <div class="d-flex align-items-center gap-3 im-navbar-auth">
                        @if (isAuthenticated)
                        {
                            <div class="dropdown d-none d-sm-block">
                                <button type="button"
                                        class="btn p-0 border-0 bg-transparent im-circle-hover position-relative"
                                        data-bs-toggle="dropdown"
                                        data-bs-display="static"
                                        aria-expanded="false"
                                        aria-label="Ver notificaciones de stock bajo">
                                    <span aria-hidden="true" class="im-icon-circle im-icon-circle-soft">
                                        <svg viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M8 1.5a3 3 0 0 0-3 3v1.087c0 .611-.134 1.214-.392 1.768L4 8.5v1h8v-1l-.608-1.145A4.207 4.207 0 0 1 11 5.587V4.5a3 3 0 0 0-3-3z"/>
                                            <path d="M14 10.5H2a.5.5 0 0 0-.5.5A1.5 1.5 0 0 0 3 12.5h10a1.5 1.5 0 0 0 1.5-1.5.5.5 0 0 0-.5-.5z"/>
                                            <path d="M6 13a2 2 0 1 0 4 0H6z"/>
                                        </svg>
                                    </span>
                                    @if (lowStockNotifications.Count > 0)
                                    {
                                        <span class="im-notification-count">@lowStockNotifications.Count</span>
                                    }
                                </button>
                                <div class="dropdown-menu dropdown-menu-end im-notification-menu p-0">
                                    <div class="p-3">
                                        <div class="d-flex justify-content-between align-items-center gap-3">
                                            <div>
                                                <div class="im-user-menu-section-title mb-1">Notificaciones</div>
                                                <div class="text-muted small">Productos con stock bajo.</div>
                                            </div>
                                            <span class="badge rounded-pill text-bg-light im-role-badge">@lowStockNotifications.Count</span>
                                        </div>
                                        <div class="im-user-menu-section">
                                            @if (lowStockNotifications.Count == 0)
                                            {
                                                <div class="text-muted small">No hay alertas de stock bajo.</div>
                                            }
                                            else
                                            {
                                                @foreach (var product in lowStockNotifications.Take(6))
                                                {
                                                    <div class="im-notification-item">
                                                        <div class="fw-semibold text-truncate">@product.Name</div>
                                                        <div class="text-muted small">Stock: @product.Stock | Minimo: @product.MinimumStock</div>
                                                    </div>
                                                }
                                            }
                                        </div>
                                        <a class="btn btn-outline-primary w-100 rounded-pill fw-semibold mt-3" asp-page="/Inventario/Index">Ver productos con stock bajo</a>
                                    </div>
                                </div>
                            </div>
                            <div class="d-inline-flex align-items-center gap-2 im-navbar-user-actions">
                                <div class="dropdown">
                                    <button type="button"
                                            class="btn p-0 border-0 bg-transparent im-user-toggle im-circle-hover"
                                            data-bs-toggle="dropdown"
                                            data-bs-display="static"
                                            aria-expanded="false"
                                            aria-label="Ver información del usuario">
                                        <span aria-hidden="true" class="im-icon-circle im-icon-circle-soft im-user-avatar">
                                            <svg viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                                                <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/>
                                                <path d="M14 14s-1-4-6-4-6 4-6 4 1 1 6 1 6-1 6-1z"/>
                                            </svg>
                                        </span>
                                    </button>
                                    <div class="dropdown-menu dropdown-menu-end im-user-menu p-0">
                                        <div class="p-3">
                                            <div class="d-flex align-items-center gap-3">
                                                <span aria-hidden="true" class="im-user-menu-avatar">
                                                    <svg viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                                                        <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/>
                                                        <path d="M14 14s-1-4-6-4-6 4-6 4 1 1 6 1 6-1 6-1z"/>
                                                    </svg>
                                                </span>
                                                <div class="flex-grow-1 overflow-hidden">
                                                    <div class="im-user-name text-truncate">@(!string.IsNullOrWhiteSpace(fullName) ? fullName : email ?? username)</div>
                                                    @if (!string.IsNullOrWhiteSpace(email))
                                                    {
                                                        <div class="text-muted small text-truncate">@email</div>
                                                    }
                                                </div>
                                            </div>
                                            <a class="btn btn-outline-primary w-100 rounded-pill fw-semibold mt-3" asp-page="/Index">Ver perfil</a>
                                            <div class="im-user-menu-section">
                                                <div class="im-user-menu-section-title">Cuenta</div>
                                                @if (!string.IsNullOrWhiteSpace(email))
                                                {
                                                    <div class="im-user-menu-item">
                                                        <span class="im-user-menu-label">Correo</span>
                                                        <span class="im-user-menu-value">@email</span>
                                                    </div>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(username))
                                                {
                                                    <div class="im-user-menu-item">
                                                        <span class="im-user-menu-label">Usuario</span>
                                                        <span class="im-user-menu-value">@username</span>
                                                    </div>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(fullName))
                                                {
                                                    <div class="im-user-menu-item">
                                                        <span class="im-user-menu-label">Nombre</span>
                                                        <span class="im-user-menu-value">@fullName</span>
                                                    </div>
                                                }
                                            </div>
                                            @if (roles.Length > 0)
                                            {
                                                <div class="im-user-menu-section">
                                                    <div class="im-user-menu-section-title">Roles</div>
                                                    <div class="d-flex flex-wrap gap-2">
                                                        @foreach (var role in roles)
                                                        {
                                                            <span class="badge rounded-pill text-bg-light im-role-badge">@role</span>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                                <span class="text-muted small d-none d-md-inline">@email</span>
                            </div>
                            <form method="post" asp-page="/Logout" class="mb-0 im-navbar-logout">
                                <button type="submit"
                                        class="btn p-0 border-0 bg-transparent im-circle-hover"
                                        data-bs-toggle="tooltip"
                                        data-bs-placement="bottom"
                                        title="Cerrar sesión"
                                        aria-label="Cerrar sesión">
                                    <span aria-hidden="true" class="im-icon-circle im-icon-circle-soft">
                                        <span class="im-title-icon">
                                            <svg viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                                                <path d="M6 2a1 1 0 0 0-1 1v3h1V3h8v10H6v-3H5v3a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V3a1 1 0 0 0-1-1H6z"/>
                                                <path d="M.5 8a.5.5 0 0 1 .5-.5h7.793L6.146 5.854a.5.5 0 1 1 .708-.708l3.5 3.5a.5.5 0 0 1 0 .708l-3.5 3.5a.5.5 0 0 1-.708-.708L8.793 8.5H1A.5.5 0 0 1 .5 8z"/>
                                            </svg>
                                        </span>
                                    </span>
                                </button>
                            </form>
                        }
                        else
                        {
                            <a class="btn btn-outline-primary btn-sm" asp-page="/Login">Iniciar sesión</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container-fluid px-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - InventoryManagement
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.6/dist/JsBarcode.all.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
