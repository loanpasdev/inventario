@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
    var inventoryValueLabels = System.Text.Json.JsonSerializer.Serialize(
        Model.InventoryValuesByCategory.Select(item => item.CategoryName));
    var inventoryValueData = System.Text.Json.JsonSerializer.Serialize(
        Model.InventoryValuesByCategory.Select(item => item.TotalInventoryValue));
    var inventoryValueUsdData = System.Text.Json.JsonSerializer.Serialize(
        Model.InventoryValuesByCategory.Select(item => Model.UsdToVesRate > 0
            ? Math.Round(item.TotalInventoryValue / Model.UsdToVesRate, 2)
            : 0));
    var stockByCategory = Model.Products
        .GroupBy(product => product.Category)
        .Select(group => new
        {
            Category = group.Key,
            Stock = group.Sum(product => product.Stock)
        })
        .OrderByDescending(item => item.Stock)
        .ToList();
    var stockByCategoryLabels = System.Text.Json.JsonSerializer.Serialize(stockByCategory.Select(item => item.Category));
    var stockByCategoryData = System.Text.Json.JsonSerializer.Serialize(stockByCategory.Select(item => item.Stock));
    var lowStockCount = Model.LowStockProducts;
    var stockStatusLabels = System.Text.Json.JsonSerializer.Serialize(new[] { "Stock bajo", "Stock OK" });
    var stockStatusData = System.Text.Json.JsonSerializer.Serialize(new[] { lowStockCount, Math.Max(Model.TotalProducts - lowStockCount, 0) });
    var unitDistribution = Model.Products
        .GroupBy(product => string.IsNullOrWhiteSpace(product.UnitOfMeasureCode) ? "Sin unidad" : product.UnitOfMeasureCode)
        .Select(group => new
        {
            Unit = group.Key,
            Count = group.Count()
        })
        .OrderByDescending(item => item.Count)
        .ToList();
    var unitDistributionLabels = System.Text.Json.JsonSerializer.Serialize(unitDistribution.Select(item => item.Unit));
    var unitDistributionData = System.Text.Json.JsonSerializer.Serialize(unitDistribution.Select(item => item.Count));
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="display-6 mb-1 im-page-title">Dashboard</h1>
        <p class="text-muted mb-0">Resumen general del inventario.</p>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info" role="alert">
        @Model.StatusMessage
    </div>
}

<div class="row row-cols-1 row-cols-md-2 row-cols-xl-4 g-3">
    <div class="col">
        <div class="card h-100 im-card im-dashboard-card">
            <div class="card-body">
                <h2 class="h6 mb-3">Total del inventario</h2>
                <div class="im-dashboard-value mb-2">VES @Model.TotalInventoryValue.ToString("N2")</div>
                @if (Model.UsdToVesRate > 0)
                {
                    <div class="text-muted small mb-2">
                        <span data-bs-toggle="tooltip" data-bs-placement="top" title="Tasa: 1 USD = VES @Model.UsdToVesRate.ToString("N2")">
                            USD @Model.TotalInventoryValueUsd.ToString("N2")
                        </span>
                    </div>
                }
                <div class="text-muted small">Valor total agrupado por categoría usando el endpoint del inventario.</div>
                <hr />
                <div class="row g-2">
                    <div class="col-12">
                        <div class="im-stat rounded border d-flex justify-content-between">
                            <span class="d-inline-flex align-items-center gap-2 text-muted">
                                <span class="im-stat-icon" aria-hidden="true">
                                    <svg viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M2.5 3A1.5 1.5 0 0 1 4 1.5h8A1.5 1.5 0 0 1 13.5 3v10A1.5 1.5 0 0 1 12 14.5H4A1.5 1.5 0 0 1 2.5 13V3zM4 2.5a.5.5 0 0 0-.5.5v10a.5.5 0 0 0 .5.5h8a.5.5 0 0 0 .5-.5V3a.5.5 0 0 0-.5-.5H4z"/>
                                        <path d="M5 5h6v1H5V5zm0 3h6v1H5V8zm0 3h4v1H5v-1z"/>
                                    </svg>
                                </span>
                                <span>Productos</span>
                            </span>
                            <strong>@Model.TotalProducts</strong>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="im-stat rounded border d-flex justify-content-between">
                            <span class="d-inline-flex align-items-center gap-2 text-muted">
                                <span class="im-stat-icon" aria-hidden="true">
                                    <svg viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M2 2.5A1.5 1.5 0 0 1 3.5 1h4.086a1.5 1.5 0 0 1 1.06.44l1.914 1.914A1.5 1.5 0 0 0 12.62 3H14.5A1.5 1.5 0 0 1 16 4.5v7A2.5 2.5 0 0 1 13.5 14H3A3 3 0 0 1 0 11V4.5A2.5 2.5 0 0 1 2.5 2H2zm.5 1A1.5 1.5 0 0 0 1 5v6a2 2 0 0 0 2 2h10.5A1.5 1.5 0 0 0 15 11.5v-7a.5.5 0 0 0-.5-.5h-1.88a2.5 2.5 0 0 1-1.768-.732L8.94 1.35A.5.5 0 0 0 8.586 1H4a1.5 1.5 0 0 0-1.5 1.5V3.5z"/>
                                    </svg>
                                </span>
                                <span>Categorías</span>
                            </span>
                            <strong>@Model.DistinctCategories</strong>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="im-stat rounded border d-flex justify-content-between">
                            <span class="d-inline-flex align-items-center gap-2 text-muted">
                                <span class="im-stat-icon" aria-hidden="true">
                                    <svg viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M7.001 1.5a1 1 0 0 1 1.998 0l.35 8.5a1 1 0 0 1-1.998 0l.35-8.5z"/>
                                        <path d="M8 12.25a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5z"/>
                                    </svg>
                                </span>
                                <span>Stock bajo</span>
                            </span>
                            <strong>@Model.LowStockProducts</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100 im-card im-dashboard-card">
            <div class="card-body">
                <h2 class="h6 mb-3">Valor por categoría</h2>
                <div class="im-chart-wrap">
                    <canvas id="inventoryValueChart"></canvas>
                </div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100 im-card im-dashboard-card">
            <div class="card-body">
                <h2 class="h6 mb-3">Stock por categoría</h2>
                <div class="im-chart-wrap">
                    <canvas id="stockByCategoryChart"></canvas>
                </div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100 im-card im-dashboard-card">
            <div class="card-body">
                <h2 class="h6 mb-3">Distribución del inventario</h2>
                <div class="im-chart-wrap mb-3">
                    <canvas id="stockStatusChart"></canvas>
                </div>
                <div class="im-chart-wrap im-chart-wrap--small">
                    <canvas id="unitDistributionChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        (function () {
            if (typeof Chart === "undefined") {
                return;
            }

            var inventoryValueLabels = @Html.Raw(inventoryValueLabels);
            var inventoryValueData = @Html.Raw(inventoryValueData);
            var inventoryValueUsdData = @Html.Raw(inventoryValueUsdData);
            var stockByCategoryLabels = @Html.Raw(stockByCategoryLabels);
            var stockByCategoryData = @Html.Raw(stockByCategoryData);
            var stockStatusLabels = @Html.Raw(stockStatusLabels);
            var stockStatusData = @Html.Raw(stockStatusData);
            var unitDistributionLabels = @Html.Raw(unitDistributionLabels);
            var unitDistributionData = @Html.Raw(unitDistributionData);

            var defaultColors = [
                "#0d6efd",
                "#20c997",
                "#ffc107",
                "#dc3545",
                "#6f42c1",
                "#fd7e14",
                "#198754",
                "#0dcaf0"
            ];

            var integerFormatter = new Intl.NumberFormat("es-VE", { maximumFractionDigits: 0 });
            var moneyFormatter = new Intl.NumberFormat("es-VE", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            var compactFormatter = new Intl.NumberFormat("es-VE", { notation: "compact", maximumFractionDigits: 1 });
            var percentFormatter = new Intl.NumberFormat("es-VE", { style: "percent", maximumFractionDigits: 1 });

            function toNumber(value) {
                var number = Number(value);
                return Number.isFinite(number) ? number : 0;
            }

            function formatInteger(value) {
                return integerFormatter.format(toNumber(value));
            }

            function formatMoneyVes(value) {
                return "VES " + moneyFormatter.format(toNumber(value));
            }

            function formatMoneyUsd(value) {
                return "USD " + moneyFormatter.format(toNumber(value));
            }

            function formatCompactVes(value) {
                return "VES " + compactFormatter.format(toNumber(value));
            }

            function formatCompactUsd(value) {
                return "USD " + compactFormatter.format(toNumber(value));
            }

            function formatPercent(part, total) {
                var totalNumber = toNumber(total);
                if (totalNumber <= 0) {
                    return percentFormatter.format(0);
                }

                return percentFormatter.format(toNumber(part) / totalNumber);
            }

            var baseOptions = {
                responsive: true,
                maintainAspectRatio: false,
                interaction: {
                    mode: "nearest",
                    intersect: false
                },
                plugins: {
                    legend: {
                        position: "bottom",
                        labels: {
                            boxWidth: 10,
                            usePointStyle: true,
                            pointStyle: "circle"
                        }
                    },
                    tooltip: {
                        padding: 10,
                        cornerRadius: 10
                    }
                }
            };

            var inventoryValueCanvas = document.getElementById("inventoryValueChart");
            if (inventoryValueCanvas && inventoryValueLabels.length > 0) {
                new Chart(inventoryValueCanvas, {
                    type: "bar",
                    data: {
                        labels: inventoryValueLabels,
                        datasets: [
                            {
                                type: "bar",
                                label: "VES",
                                data: inventoryValueData,
                                backgroundColor: "#0d6efd",
                                borderRadius: 8,
                                yAxisID: "yVes",
                                order: 2
                            },
                            {
                                type: "line",
                                label: "USD",
                                data: inventoryValueUsdData,
                                borderColor: "#198754",
                                backgroundColor: "#198754",
                                pointBackgroundColor: "#198754",
                                pointBorderColor: "#ffffff",
                                pointBorderWidth: 2,
                                pointRadius: 4,
                                pointHoverRadius: 5,
                                tension: 0.35,
                                yAxisID: "yUsd",
                                order: 1
                            }
                        ]
                    },
                    options: {
                        ...baseOptions,
                        plugins: {
                            ...baseOptions.plugins,
                            tooltip: {
                                ...baseOptions.plugins.tooltip,
                                callbacks: {
                                    label: function (context) {
                                        var value = context.parsed.y;
                                        return context.dataset.label === "USD"
                                            ? formatMoneyUsd(value)
                                            : formatMoneyVes(value);
                                    }
                                }
                            },
                        },
                        scales: {
                            x: {
                                grid: { display: false },
                                ticks: { maxRotation: 0, autoSkip: true }
                            },
                            yVes: {
                                type: "linear",
                                position: "left",
                                grid: { color: "rgba(15, 23, 42, 0.08)" },
                                ticks: {
                                    callback: function (value) {
                                        return formatCompactVes(value);
                                    }
                                }
                            },
                            yUsd: {
                                type: "linear",
                                position: "right",
                                grid: { drawOnChartArea: false },
                                ticks: {
                                    callback: function (value) {
                                        return formatCompactUsd(value);
                                    }
                                }
                            }
                        }
                    }
                });
            }

            var stockByCategoryCanvas = document.getElementById("stockByCategoryChart");
            if (stockByCategoryCanvas && stockByCategoryLabels.length > 0) {
                new Chart(stockByCategoryCanvas, {
                    type: "bar",
                    data: {
                        labels: stockByCategoryLabels,
                        datasets: [{
                            label: "Stock",
                            data: stockByCategoryData,
                            backgroundColor: "#20c997",
                            borderRadius: 10,
                            maxBarThickness: 22
                        }]
                    },
                    options: {
                        ...baseOptions,
                        indexAxis: "y",
                        plugins: {
                            ...baseOptions.plugins,
                            tooltip: {
                                ...baseOptions.plugins.tooltip,
                                callbacks: {
                                    label: function (context) {
                                        return "Stock: " + formatInteger(context.parsed.y);
                                    }
                                }
                            }
                        },
                        scales: {
                            x: {
                                grid: { color: "rgba(15, 23, 42, 0.08)" },
                                ticks: {
                                    callback: function (value) {
                                        return formatInteger(value);
                                    }
                                }
                            },
                            y: {
                                grid: { display: false }
                            }
                        }
                    }
                });
            }

            var stockStatusCanvas = document.getElementById("stockStatusChart");
            if (stockStatusCanvas && stockStatusLabels.length > 0) {
                var stockStatusTotal = stockStatusData.reduce(function (sum, value) { return sum + toNumber(value); }, 0);
                new Chart(stockStatusCanvas, {
                    type: "doughnut",
                    data: {
                        labels: stockStatusLabels,
                        datasets: [{
                            data: stockStatusData,
                            backgroundColor: ["#dc3545", "#198754"],
                            borderWidth: 6,
                            borderColor: "#ffffff",
                            hoverOffset: 6
                        }]
                    },
                    options: {
                        ...baseOptions,
                        cutout: "70%",
                        plugins: {
                            ...baseOptions.plugins,
                            tooltip: {
                                ...baseOptions.plugins.tooltip,
                                callbacks: {
                                    label: function (context) {
                                        var value = toNumber(context.parsed);
                                        return context.label + ": " + formatInteger(value) + " (" + formatPercent(value, stockStatusTotal) + ")";
                                    }
                                }
                            }
                        }
                    }
                });
            }

            var unitDistributionCanvas = document.getElementById("unitDistributionChart");
            if (unitDistributionCanvas && unitDistributionLabels.length > 0) {
                var unitTotal = unitDistributionData.reduce(function (sum, value) { return sum + toNumber(value); }, 0);
                new Chart(unitDistributionCanvas, {
                    type: "bar",
                    data: {
                        labels: unitDistributionLabels,
                        datasets: [{
                            data: unitDistributionData,
                            label: "Productos",
                            backgroundColor: defaultColors.slice(0, unitDistributionLabels.length),
                            borderRadius: 10,
                            maxBarThickness: 20
                        }]
                    },
                    options: {
                        ...baseOptions,
                        indexAxis: "y",
                        plugins: {
                            ...baseOptions.plugins,
                            tooltip: {
                                ...baseOptions.plugins.tooltip,
                                callbacks: {
                                    label: function (context) {
                                        var value = toNumber(context.parsed.x);
                                        return context.label + ": " + formatInteger(value) + " (" + formatPercent(value, unitTotal) + ")";
                                    }
                                }
                            }
                        },
                        scales: {
                            x: {
                                grid: { color: "rgba(15, 23, 42, 0.08)" },
                                ticks: {
                                    callback: function (value) {
                                        return formatInteger(value);
                                    }
                                }
                            },
                            y: {
                                grid: { display: false }
                            }
                        }
                    }
                });
            }
        })();
    </script>
}
